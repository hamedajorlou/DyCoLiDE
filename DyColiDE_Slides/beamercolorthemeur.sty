\ProvidesPackageRCS $Header: /cvsroot/latex-beamer/latex-beamer/themes/color/beamercolorthemeur.sty,v 1.4 2007/01/28 20:48:24 tantau Exp $

\definecolor{pennred}{cmyk}{0,1,0.65,0.34}
\definecolor{uryellow}{cmyk}{0,0.133,1,0}
\definecolor{urblue}{cmyk}{1,0.449,0,0.502}



\mode<presentation>

\setbeamercolor*{palette primary}{use=structure,fg=white,bg= urblue}
\setbeamercolor*{palette secondary}{use=structure,fg=white,bg= urblue}
\setbeamercolor*{palette tertiary}{use=structure,fg=white,bg= urblue}
\setbeamercolor*{palette quaternary}{fg=white,bg= pennred}

\setbeamercolor*{sidebar}{use=structure,bg= urblue}
  
\setbeamercolor*{palette sidebar primary}{use=structure,fg=structure.fg!10}
\setbeamercolor*{palette sidebar secondary}{fg=white}
\setbeamercolor*{palette sidebar tertiary}{use=structure,fg=structure.fg!50}
\setbeamercolor*{palette sidebar quaternary}{fg=white}

\setbeamercolor*{titlelike}{parent=palette primary}

\setbeamercolor*{separation line}{}
\setbeamercolor*{fine separation line}{}

\setbeamercolor{itemize item}{fg=urblue}
\setbeamercolor{itemize subitem}{fg=urblue}
\setbeamercolor{itemize subsubitem}{fg=urblue}
\setbeamercolor{enumerate item}{fg=urblue}
\setbeamercolor{enumerate subitem}{fg=urblue}
\setbeamercolor{enumerate subsubitem}{fg=urblue}
\setbeamercolor{description item}{fg=urblue}


\mode
<all>
